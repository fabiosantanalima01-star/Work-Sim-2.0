rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Collection: test
    match /test/connection {
      allow read: if true;
    }

    // Standard Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Student Validation Helper
    function isValidStudent(data) {
      return (data.get('id', null) == null || (data.id is string && data.id.size() <= 64)) &&
             (data.get('nomeCompleto', null) == null || (data.nomeCompleto is string && data.nomeCompleto.size() <= 200)) &&
             (data.get('matricula', null) == null || (data.matricula is string && data.matricula.size() <= 64)) &&
             (data.get('sala', null) == null || (data.sala is string && data.sala.size() <= 32)) &&
             (data.get('ano', null) == null || data.ano is int) &&
             (data.get('cargo', null) == null || (data.cargo is string && data.cargo.size() <= 128)) &&
             (data.get('xp', null) == null || (data.xp is int && data.xp >= 0)) &&
             (data.get('precisao', null) == null || (data.precisao is number && data.precisao >= 0 && data.precisao <= 100)) &&
             (data.get('faseAtual', null) == null || (data.faseAtual is int && data.faseAtual >= 0 && data.faseAtual <= 8)) &&
             (data.get('status', null) == null || (data.status is string)) &&
             (data.get('senha', null) == null || (data.senha is string)) &&
             (data.get('isVeterano', null) == null || data.isVeterano is bool) &&
             (data.get('dispositivoVinculado', null) == null || (data.dispositivoVinculado is string)) &&
             (data.get('respostasDesafios', null) == null || data.respostasDesafios is map) &&
             (data.get('tempoAtivoSegundos', null) == null || data.tempoAtivoSegundos is int) &&
             (data.get('tempoAcumuladoXP', null) == null || data.tempoAcumuladoXP is int) &&
             (data.get('casosResolvidosNoCiclo', null) == null || data.casosResolvidosNoCiclo is int) &&
             (data.get('focoStatus', null) == null || (data.focoStatus is string)) &&
             (data.get('saidasTela', null) == null || data.saidasTela is int) &&
             (data.get('soundTheme', null) == null || (data.soundTheme is string)) &&
             (data.get('mensagensChat', null) == null || data.mensagensChat is list) &&
             (data.get('pausasBanheiroUsadas', null) == null || data.pausasBanheiroUsadas is int) &&
             (data.get('pausaAtiva', null) == null || (data.pausaAtiva is string)) &&
             (data.get('pauseStartTime', null) == null || data.pauseStartTime is int) &&
             (data.get('contagemDuvidasDia', null) == null || data.contagemDuvidasDia is int) &&
             (data.get('recuperadoDeBloqueio', null) == null || data.recuperadoDeBloqueio is bool) &&
             (data.get('streakFasesAutonomas', null) == null || data.streakFasesAutonomas is int) &&
             (data.get('duvidaPendenteTexto', null) == null || (data.duvidaPendenteTexto is string)) &&
             (data.get('duvidasHistorico', null) == null || data.duvidasHistorico is list) &&
             (data.get('timeId', null) == null || (data.timeId is string)) &&
             (data.get('timeLider', null) == null || data.timeLider is bool) &&
             (data.get('timeViceLider', null) == null || data.timeViceLider is bool) &&
             (data.get('chamadaNumero', null) == null || (data.chamadaNumero is string)) &&
             (data.get('xpAntecedente', null) == null || data.xpAntecedente is int) &&
             (data.get('ultimaDataAcesso', null) == null || (data.ultimaDataAcesso is string)) &&
             (data.get('foto', null) == null || (data.foto is string && data.foto.size() <= 1000000)) &&
             (data.get('email', null) == null || (data.email is string)) &&
             (data.get('contratoAssinado', null) == null || data.contratoAssinado is bool) &&
             (data.get('tentativaFraude', null) == null || data.tentativaFraude is int) &&
             (data.get('contaBloqueada', null) == null || data.contaBloqueada is bool) &&
             (data.get('badges', null) == null || data.badges is list);
    }

    // Log Validation Helper
    function isValidLog(data) {
      return data.studentId is string && data.studentId.size() <= 64 &&
             data.type is string && data.type.size() <= 64 &&
             data.action is string && data.action.size() <= 128 &&
             data.timestamp is string && data.timestamp.size() <= 128;
    }

    // Custom Challenge Validation Helper
    function isValidCustomChallenge(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.fase is int && data.fase >= 0 && data.fase <= 8 &&
             data.titulo is string && data.titulo.size() <= 256 &&
             data.tipo is string &&
             data.focoTecnico is string &&
             data.tempoLimiteMinutos is int && data.tempoLimiteMinutos > 0 &&
             data.xpRecompensa is int && data.xpRecompensa >= 0 &&
             data.queixa is string &&
             (data.bloco == null || data.bloco is string) &&
             (data.empregado == null || data.empregado is map) &&
             (data.gabarito == null || data.gabarito is map) &&
             (data.opcoes == null || data.opcoes is list);
    }

    // Feedback Validation Helper
    function isValidFeedback(data) {
      return data.id is string && data.id.size() <= 64 &&
             data.veteranName is string && data.veteranName.size() <= 200 &&
             data.veteranUser is string && data.veteranUser.size() <= 64 &&
             data.category is string && data.category.size() <= 256 &&
             data.text is string && data.text.size() <= 5000 &&
             data.timestamp is string && data.timestamp.size() <= 128 &&
             data.status is string && (data.status == 'Não Lido' || data.status == 'Lido' || data.status == 'Resolvido') &&
             (data.emailTo == null || data.emailTo is string);
    }

    // Collection: students
    match /students/{studentId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(studentId) && isValidStudent(incoming());
      allow update: if isSignedIn() && isValidId(studentId) && isValidStudent(incoming());
      allow delete: if isSignedIn() && isValidId(studentId);
    }

    // Collection: logs
    match /logs/{logId} {
      allow create: if isSignedIn() && isValidId(logId) && isValidLog(incoming());
      allow get, list: if isSignedIn(); // Professor or audit
    }

    // Collection: custom_challenges
    match /custom_challenges/{challengeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(challengeId) && isValidCustomChallenge(incoming());
      allow update: if isSignedIn() && isValidId(challengeId) && isValidCustomChallenge(incoming());
      allow delete: if isSignedIn() && isValidId(challengeId);
    }

    // Collection: feedbacks
    match /feedbacks/{feedbackId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(feedbackId) && isValidFeedback(incoming());
      allow update: if isSignedIn() && isValidId(feedbackId) && isValidFeedback(incoming());
      allow delete: if isSignedIn() && isValidId(feedbackId);
    }

    // Collection: broadcasts (Real-time login signals)
    match /broadcasts/{broadcastId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }
  }
}
