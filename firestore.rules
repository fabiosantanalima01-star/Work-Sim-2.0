rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Collection: test
    match /test/connection {
      allow read: if true;
    }

    // Standard Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Student Validation Helper
    function isValidStudent(data) {
      return data.get('id', '') is string;
    }

    // Log Validation Helper
    function isValidLog(data) {
      return data.get('studentId', '') is string;
    }

    // Custom Challenge Validation Helper
    function isValidCustomChallenge(data) {
      return data.get('id', '') is string;
    }

    // Feedback Validation Helper
    function isValidFeedback(data) {
      return data.get('id', '') is string;
    }

    // Collection: students
    match /students/{studentId} {
      allow read: if true;
      allow create, update: if isValidStudent(incoming());
      allow delete: if isProfessor();
    }

    function isProfessor() {
      return isSignedIn() && (request.auth.token.email.lower() == "fabiosantanalima01@gmail.com");
    }

    // Collection: logs
    match /logs/{logId} {
      allow create: if isValidLog(incoming());
      allow get, list: if isSignedIn(); // Professor or audit
    }

    // Collection: custom_challenges
    match /custom_challenges/{challengeId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidCustomChallenge(incoming());
      allow update: if isSignedIn() && isValidCustomChallenge(incoming());
      allow delete: if isSignedIn();
    }

    // Collection: feedbacks
    match /feedbacks/{feedbackId} {
      allow read: if true;
      allow create: if isValidFeedback(incoming());
      allow update: if isValidFeedback(incoming());
      allow delete: if isSignedIn();
    }

    // Collection: broadcasts (Real-time login signals)
    match /broadcasts/{broadcastId} {
      allow read: if true;
      allow create: if true;
    }
  }
}
